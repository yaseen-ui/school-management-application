// ---------------- Generators & Datasource ----------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

// ---------------- Enums ----------------
enum UserType {
  company
  tenant
}

enum EntityStatus {
  active
  inactive
  suspended
}

enum Gender {
  Male
  Female
  Other
}

enum AcademicYearStatus {
  draft
  active
  archived
}

enum EnrollmentStatus {
  active
  promoted
  transferred
  left
}

enum AttendanceStatus {
  present
  absent
  late
  half_day
  excused
}

enum DiscountType {
  percentage
  fixed
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  upi
  cheque
  online
  other
}

enum TransactionType {
  debit
  credit
}

enum PaymentStatus {
  paid
  partial
  pending
  refunded
  cancelled
}

enum FeeAllocationMethod {
  equal
  custom
}

enum EmployeeType {
  teacher
  driver
  clerk
  office_boy
  admin
  accountant
  security
  cleaner
  other
}

enum AttendanceType {
  period_wise
  shift_wise
}

enum AttendanceContextType {
  regular
  exam
  event
  seminar
  sports
  assembly
  lab
  field_trip
  other
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum TeacherRole {
  subject_teacher
  class_teacher
  assistant_teacher
  lab_incharge
}

enum ExamType {
  weekly
  quarterly
  half_yearly
  annually
}

enum ExamStatus {
  draft
  published
  in_progress
  completed
  cancelled
  locked
  archived
}

enum ExamScheduleStatus {
  pending
  scheduled
  completed
  cancelled
}

enum HolidayType {
  public
  school
  optional
  vacation
}

enum SubscriptionPlan {
  free
  starter
  growth
  enterprise
}

enum ExpertiseLevel {
  beginner
  intermediate
  advanced
  expert
}

enum PeriodType {
  class
  break
  lunch
  sports
  leisure
  study_hour
}

enum RoomCategory {
  ac
  non_ac
  deluxe
}

enum VehicleCategoryType {
  bus
  van
  car
  auto
}

enum VehicleAmenity {
  ac
  non_ac
  deluxe
  standard
}

enum RoomType {
  classroom
  laboratory
  library
  auditorium
  office
  staff_room
  computer_lab
  science_lab
  language_lab
  sports_hall
  art_room
  music_room
  seminar_hall
  conference_room
  other
}


// ---------------- Core: Tenants, Users, Roles ----------------
model Tenant {
  id               String           @id @default(uuid())
  schoolName       String
  contactAddress   Json?
  contactPhone     String?
  contactEmail     String?
  subscriptionPlan SubscriptionPlan @default(free)
  domain           String?          @unique
  logo             String?
  caption          String?
  defaultTermCount Int      @default(1) // default number of fee terms for this institution

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relations
  users               User[]
  roles               Role[]
  courses             Course[]
  grades              Grade[]
  sections            Section[]
  subjects            Subject[]
  sectionSubjects     SectionSubject[]
  students            Student[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  stockAdjustments    StockAdjustment[]
  uploads             Upload[]

  // runtime academics
  academicYears              AcademicYear[]
  enrollments                StudentEnrollment[]
  teachers                   Teacher[]
  teacherQualifications      TeacherQualification[]
  teacherEmploymentHistory   TeacherEmploymentHistory[]
  teacherAssignments         TeacherAssignment[]
  teacherCapabilities        TeacherCapability[]
  timetableStructures        TimetableStructure[]
  timetablePeriods           TimetablePeriod[]
  timetableEntries           TimetableEntry[]
  attendanceSessions         AttendanceSession[]
  studentEnrollmentElectives StudentEnrollmentElective[]
  attendanceMarks            AttendanceMark[]

  // parents
  parents        Parent[]
  studentParents StudentParent[]

  // exams & grading
  exams               Exam[]
  examTargetGrades    ExamTargetGrade[]
  examTargetSections  ExamTargetSection[]
  examSchedules       ExamSchedule[]
  examSchedulePapers  ExamSchedulePaper[]
  examMarks           ExamMark[]
  gradingScales       GradingScale[]
  gradingBands        GradingBand[]

  // calendar
  holidays Holiday[]

  // infrastructure
  buildings Building[]
  floors    Floor[]
  rooms     Room[]

  // teacher availability
  teacherAvailabilities TeacherAvailability[]

  // fee management
  feeHeads        FeeHead[]
  sectionFees     SectionFee[]
  sectionFeeHeads SectionFeeHead[]
  feeTerms        FeeTerm[]
  studentFees     StudentFee[]
  studentFeeHeads StudentFeeHead[]
  feePayments     FeePayment[]
  feeRefunds      FeeRefund[]

  // store
  storeCategories      StoreCategory[]
  storeProducts        StoreProduct[]
  storeProductSections StoreProductSection[]
  storeKits            StoreKit[]
  storeKitItems        StoreKitItem[]
  storeKitSections     StoreKitSection[]
  storeOrders          StoreOrder[]
  storeOrderItems      StoreOrderItem[]
  storePendingItems    StorePendingItem[]
  storeDues            StoreDue[]
  storeDuePayments     StoreDuePayment[]
  storeReturns         StoreReturn[]

  // accounts / ledger
  accountCategories    AccountCategory[]
  accountTransactions  AccountTransaction[]

  // payroll
  salaryComponents        SalaryComponent[]
  employeeCompensations   EmployeeCompensation[]
  compensationComponents  CompensationComponent[]
  compensationHistory     CompensationHistory[]
  payrollBatches          PayrollBatch[]
  payrollRecords          PayrollRecord[]

  // transportation
  vehicleCategories           VehicleCategory[]
  vehicles                    Vehicle[]
  vehicleDriverAssignments    VehicleDriverAssignment[]
  pickupPoints                PickupPoint[]
  studentTransportAssignments StudentTransportAssignment[]

  @@map("tenants")
}

model User {
  id       String   @id @default(uuid())
  tenantId String?
  fullName String
  email    String
  password String
  userType UserType @default(tenant)
  roleId   String?

  // OTP fields (consider extracting to dedicated OtpToken table later)
  otp          String?
  otpExpiresAt DateTime?
  otpPurpose   String? // 'login' | 'password_reset' | 'first_login'
  isFirstLogin Boolean   @default(true)

  phone String?

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role   Role?   @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  // optional domain mappings
  teacher Teacher?
  parent  Parent?

  // attendance sessions taken by this user
  attendanceSessionsTaken AttendanceSession[]

  // fee management
  collectedPayments FeePayment[] // payments collected by this user
  processedRefunds  FeeRefund[]  // refunds processed by this user

  // store
  createdStoreOrders       StoreOrder[]
  createdStoreDues         StoreDue[]          @relation("createdStoreDues")
  updatedStoreDues         StoreDue[]          @relation("updatedStoreDues")
  createdStoreDuePayments  StoreDuePayment[]   @relation("createdStoreDuePayments")
  createdStoreReturns      StoreReturn[]        @relation("createdStoreReturns")
  createdStorePendingItems StorePendingItem[]

  // payroll
  createdSalaryComponents      SalaryComponent[] @relation("createdSalaryComponents")
  updatedSalaryComponents      SalaryComponent[] @relation("updatedSalaryComponents")
  createdEmployeeCompensations EmployeeCompensation[]
  updatedEmployeeCompensations EmployeeCompensation[] @relation("updatedEmployeeCompensation")
  changedCompensationHistories CompensationHistory[]
  createdPayrollBatches        PayrollBatch[]
  processedPayrollBatches      PayrollBatch[]         @relation("processedPayrollBatch")
  createdPayrollRecords        PayrollRecord[]

  // accounts
  createdAccountTransactions AccountTransaction[]
  voidedAccountTransactions  AccountTransaction[]  @relation("voidedAccountTransaction")

  // NOTE: For UserType.company rows (tenantId IS NULL), Postgres treats multiple
  // NULL tenantIds as distinct, so the composite unique below does not prevent
  // duplicate emails. Add this partial unique index in a raw SQL migration:
  //   CREATE UNIQUE INDEX users_company_email_unique
  //     ON users (email) WHERE tenant_id IS NULL;
  @@unique([tenantId, email], name: "user_email_per_tenant")
  @@unique([id, tenantId], name: "user_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  roleName    String
  description String?
  permissions Json

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  users  User[]

  @@unique([id, tenantId], name: "role_tenant_identity")
  @@unique([tenantId, roleName], name: "uniqueRoleNamePerTenant")
  @@index([tenantId])
  @@map("roles")
}

// ---------------- Academics: Courses, Grades, Sections, Subjects, SectionSubjects ----------------
model Course {
  id          String   @id @default(uuid())
  tenantId    String
  courseName  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  grades   Grade[]
  subjects Subject[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  @@unique([id, tenantId], name: "course_tenant_identity")
  @@index([tenantId])
  @@map("courses")
}

model Grade {
  id        String   @id @default(uuid())
  tenantId  String
  courseId  String
  gradeName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course Course @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  sections    Section[]
  students    Student[] // current snapshot
  enrollments StudentEnrollment[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  // exam target audience
  examTargetGrades ExamTargetGrade[]

  @@unique([id, tenantId], name: "grade_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, courseId])
  @@map("grades")
}

model Section {
  id             String         @id @default(uuid())
  tenantId       String
  gradeId        String
  sectionName    String
  structureId         String? // which timetable structure this section follows
  roomId              String? // dedicated classroom for this section
  sectionInChargeId   String? // teacher assigned as section in-charge

  // Attendance configuration
  attendanceType AttendanceType @default(period_wise)
  shifts         Json?          // [{name:"Morning",sortOrder:1},{name:"Afternoon",sortOrder:2}] — only for shift_wise

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  grade     Grade               @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  structure TimetableStructure? @relation(fields: [structureId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  room      Room?               @relation(fields: [roomId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  sectionInCharge Teacher?      @relation(fields: [sectionInChargeId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  sectionSubjects SectionSubject[]
  students        Student[] // current snapshot
  enrollments     StudentEnrollment[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  // attendance sessions
  attendanceSessions AttendanceSession[]

  // fee management
  sectionFees SectionFee[]

  // store
  storeProductSections StoreProductSection[]
  storeKitSections     StoreKitSection[]

  // exam schedules
  examSchedules      ExamSchedule[]
  examTargetSections ExamTargetSection[]

  @@unique([id, tenantId], name: "section_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, gradeId])
  @@index([tenantId, structureId])
  @@index([tenantId, roomId])
  @@map("sections")
}

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  subjectName String
  courseId    String
  isCommon    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course Course @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  sectionSubjects SectionSubject[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  @@unique([id, tenantId], name: "subject_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, courseId])
  @@map("subjects")
}

model SectionSubject {
id         String   @id @default(uuid())
  tenantId   String
  sectionId  String
  subjectId  String
  isElective Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  section Section @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  electiveSelections StudentEnrollmentElective[]
  examSchedulePapers ExamSchedulePaper[]
  attendanceSessions AttendanceSession[]

  @@unique([tenantId, sectionId, subjectId], name: "sectionSubjectUnique")
  @@unique([id, tenantId], name: "section_subject_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, sectionId])
  @@index([tenantId, subjectId])
  @@map("section_subjects")
}

// ---------------- Academic Year & Enrollments ----------------
model AcademicYear {
  id        String             @id @default(uuid())
  tenantId  String
  name      String // e.g., "2025-26"
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(draft)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  enrollments        StudentEnrollment[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  holidays           Holiday[]

  exams               Exam[]
  attendanceSessions  AttendanceSession[]

  // fee management
  sectionFees SectionFee[]

  // store
  storeOrders StoreOrder[]

  // NOTE: Only one AcademicYear may be `active` per tenant. Prisma cannot
  // express partial unique indexes; add this in a raw SQL migration:
  //   CREATE UNIQUE INDEX academic_year_one_active_per_tenant
  //     ON academic_years (tenant_id) WHERE status = 'active';
  @@unique([tenantId, name], name: "academicYearNamePerTenant")
  @@unique([id, tenantId], name: "academic_year_tenant_identity")
  @@index([tenantId, status])
  @@map("academic_years")
}

model StudentEnrollment {
  id             String           @id @default(uuid())
  tenantId       String
  studentId      String
  academicYearId String
  gradeId        String
  sectionId      String
  rollNumber     String?
  status         EnrollmentStatus @default(active)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  student      Student      @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  grade        Grade        @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section      Section      @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  electiveSelections StudentEnrollmentElective[]
  attendanceMarks    AttendanceMark[]
  examMarks          ExamMark[]

  // fee management
  studentFee StudentFee?

  // store
  storeOrders StoreOrder[]
  storeDues   StoreDue[]

  // transportation
  transportAssignments StudentTransportAssignment[]

  @@unique([tenantId, studentId, academicYearId], name: "oneEnrollmentPerYear")
  @@unique([id, tenantId], name: "student_enrollment_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, gradeId])
  @@index([tenantId, sectionId])
  @@map("student_enrollments")
}

model StudentEnrollmentElective {
  id               String   @id @default(uuid())
  tenantId         String
  enrollmentId     String
  sectionSubjectId String
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  enrollment     StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject SectionSubject    @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, enrollmentId, sectionSubjectId], name: "uniqueElectiveSelection")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, sectionSubjectId])
  @@map("student_enrollment_electives")
}

// ---------------- Teachers & Assignments ----------------
model Teacher {
  id       String  @id @default(uuid())
  tenantId String
  userId   String? @unique

  fullName     String
  email        String?
  phone        String?
  gender       Gender?
  employeeCode String?

  // Employee type (teacher by default, can be driver, clerk, etc.)
  employeeType EmployeeType @default(teacher)

  // Onboarding profile
  profilePhotoUrl   String?
  dateOfBirth       DateTime?
  dateOfJoining     DateTime?
  yearsOfExperience Float?

  // Government ID (for all non-teaching staff)
  governmentIdType   String?  // "aadhar", "pan", "voter_id", "passport"
  governmentIdNumber String?
  governmentIdUrl    String?  // GCP upload URL for ID document

  // Driver-specific fields (nullable, only for employeeType = driver)
  drivingLicenseNumber    String?
  drivingLicenseUrl       String?  // GCP upload URL
  drivingExperienceYears  Int?
  vehicleType             String?  // "bus", "van", "car", "auto"
  licenseExpiryDate       DateTime?
  medicalCertificateUrl   String?  // GCP upload URL

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user   User?  @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  assignments       TeacherAssignment[]
  capabilities      TeacherCapability[]
  qualifications    TeacherQualification[]
  employmentHistory TeacherEmploymentHistory[]
  availabilities    TeacherAvailability[]
  sectionsInCharge  Section[]
  examPapersInCharge ExamSchedulePaper[]

  // payroll
  compensations      EmployeeCompensation[]
  compensationHistory CompensationHistory[]
  payrollRecords     PayrollRecord[]

  // transportation
  vehicleDriverAssignments VehicleDriverAssignment[]

  @@unique([userId, tenantId], name: "teacher_user_tenant_unique")
  @@unique([tenantId, employeeCode], name: "teacherCodePerTenant")
  @@unique([id, tenantId], name: "teacher_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("teachers")
}

model TeacherQualification {
  id                String   @id @default(uuid())
  tenantId          String
  teacherId         String
  qualificationName String // B.Sc, M.Sc, B.Ed, PhD, etc.
  specialization    String?
  institution       String?
  score             Float? // percentage or CGPA
  yearOfPassing     Int?
  documentUrl       String? // reference to Upload.fileUrl
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "teacher_qualification_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, teacherId])
  @@map("teacher_qualifications")
}

model TeacherEmploymentHistory {
  id               String    @id @default(uuid())
  tenantId         String
  teacherId        String
  organizationName String
  role             String // designation / position
  startDate        DateTime?
  endDate          DateTime?
  reasonForLeaving String?
  experienceYears  Float? // snapshot at the time of entry
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "teacher_employment_history_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, teacherId])
  @@map("teacher_employment_history")
}

model TeacherAssignment {
  id               String      @id @default(uuid())
  tenantId         String
  academicYearId   String
  teacherId        String
  sectionSubjectId String
  role             TeacherRole @default(subject_teacher)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  academicYear   AcademicYear   @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  teacher        Teacher        @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject SectionSubject @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  timetableEntries   TimetableEntry[]

  @@unique([tenantId, academicYearId, teacherId, sectionSubjectId], name: "uniqueTeacherAssignment")
  @@unique([id, tenantId], name: "teacher_assignment_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, teacherId])
  @@index([tenantId, sectionSubjectId])
  @@map("teacher_assignments")
}

// ---------------- Teacher Capabilities (what a teacher CAN teach) ----------------
model TeacherCapability {
  id        String         @id @default(uuid())
  tenantId  String
  teacherId String
  subjectId String

  // Optional scoping: null means "all courses" or "all grades"
  courseId String?
  gradeId  String?
  sectionId String?

  expertiseLevel   ExpertiseLevel @default(intermediate)
  isPrimary        Boolean        @default(false)
  priorityScore    Int            @default(50)
  canBeClassTeacher Boolean       @default(false)
  remarks          String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  course  Course? @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  grade   Grade?  @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section? @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  // NOTE: No composite unique with nullable courseId/gradeId to avoid PostgreSQL null uniqueness issues.
  // Duplicate prevention is handled in service logic.
  @@unique([id, tenantId], name: "teacher_capability_tenant_identity")
  @@index([tenantId, teacherId])
  @@index([tenantId, subjectId])
  @@index([tenantId, courseId])
  @@index([tenantId, gradeId])
  @@index([tenantId, sectionId])
  @@map("teacher_capabilities")
}

// ---------------- Teacher Availability (recurring weekly schedule) ----------------
model TeacherAvailability {
  id          String    @id @default(uuid())
  tenantId    String
  teacherId   String
  dayOfWeek   DayOfWeek
  startTime   Int       // minutes from midnight (360 = 6:00 AM)
  endTime     Int       // minutes from midnight (1080 = 6:00 PM)
  isAvailable Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, teacherId, dayOfWeek, startTime, endTime], name: "uniqueTeacherAvailabilitySlot")
  @@unique([id, tenantId], name: "teacher_availability_tenant_identity")
  @@index([tenantId, teacherId])
  @@map("teacher_availability")
}

// ---------------- Timetable Structures & Periods ----------------
model TimetableStructure {
  id          String   @id @default(uuid())
  tenantId    String
  name        String // "Primary", "Secondary", "Pre-Primary"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  periods TimetablePeriod[]
  sections Section[]

  @@unique([tenantId, name], name: "uniqueStructureNamePerTenant")
  @@unique([id, tenantId], name: "timetable_structure_tenant_identity")
  @@index([tenantId])
  @@map("timetable_structures")
}

model TimetablePeriod {
  id          String     @id @default(uuid())
  tenantId    String
  structureId String
  name        String // "P1", "P2", "LAB-1", "FULL_DAY" (sentinel for daily-mark schools)
  type        PeriodType @default(class)
  startTime   Int // minutes from midnight, 0-1439; e.g. 09:00 = 540
  endTime     Int // minutes from midnight, 0-1439; e.g. 09:45 = 585
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt


  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structure TimetableStructure  @relation(fields: [structureId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  entries   TimetableEntry[]
  attendanceSessions AttendanceSession[]

  @@unique([tenantId, structureId, name], name: "uniquePeriodNamePerStructure")
  @@unique([id, tenantId], name: "timetable_period_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, structureId])
  @@map("timetable_periods")
}

model TimetableEntry {
  id                  String    @id @default(uuid())
  tenantId            String
  academicYearId      String
  dayOfWeek           DayOfWeek
  periodId            String
  sectionSubjectId    String
  teacherAssignmentId String?
  room                String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  academicYear      AcademicYear       @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  period            TimetablePeriod    @relation(fields: [periodId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject    SectionSubject     @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  // NoAction (not SetNull) because the composite FK includes the required tenantId.
  // Admin must reassign or clear teacherAssignmentId before deleting a TeacherAssignment.
  teacherAssignment TeacherAssignment? @relation(fields: [teacherAssignmentId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)

  @@unique([id, tenantId], name: "timetable_entry_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, sectionSubjectId])
  @@index([tenantId, periodId])
  @@map("timetable_entries")
}

// ---------------- Infrastructure: Buildings, Floors, Rooms ----------------
model Building {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  description String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  floors Floor[]

  @@unique([id, tenantId], name: "building_tenant_identity")
  @@unique([tenantId, name], name: "uniqueBuildingNamePerTenant")
  @@index([tenantId])
  @@map("buildings")
}

model Floor {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  floorNumber Int
  name        String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  building Building @relation(fields: [buildingId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  rooms    Room[]

  @@unique([id, tenantId], name: "floor_tenant_identity")
  @@unique([tenantId, buildingId, floorNumber], name: "uniqueFloorPerBuilding")
  @@index([tenantId])
  @@index([tenantId, buildingId])
  @@map("floors")
}

model Room {
  id           String       @id @default(uuid())
  tenantId     String
  floorId      String
  roomNumber   String
  roomName     String?
  roomType     RoomType     @default(classroom)
  roomCategory RoomCategory?
  capacity     Int
  status       EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  floor    Floor     @relation(fields: [floorId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sections Section[]

  @@unique([id, tenantId], name: "room_tenant_identity")
  @@unique([tenantId, floorId, roomNumber], name: "uniqueRoomPerFloor")
  @@index([tenantId])
  @@index([tenantId, floorId])
  @@index([tenantId, status])
  @@map("rooms")
}

// ---------------- Transportation Module ----------------

/// Vehicle categories define the type and amenities of vehicles
/// e.g., "Deluxe Bus (AC, 40 seats)", "Standard Van (Non-AC, 12 seats)"
model VehicleCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g., "Deluxe Bus", "Standard Van", "AC Car"
  type        VehicleCategoryType // bus, van, car, auto
  occupancy   Int      // number of people it can carry (e.g., 40, 30, 5, 10)
  amenities   VehicleAmenity[] // ac, non_ac, deluxe, standard
  description String?
  isActive    Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  vehicles Vehicle[]
  studentTransportAssignments StudentTransportAssignment[]

  @@unique([tenantId, name], name: "uniqueVehicleCategoryPerTenant")
  @@unique([id, tenantId], name: "vehicle_category_tenant_identity")
  @@index([tenantId])
  @@map("vehicle_categories")
}

/// Individual vehicles registered in the system
model Vehicle {
  id                String   @id @default(uuid())
  tenantId          String
  categoryId        String
  name              String   // e.g., "Bus 01", "Deluxe Bus A"
  registrationNumber String? // e.g., "KA-01-AB-1234"
  capacity          Int      // actual seating capacity (may differ from category occupancy)
  description       String?
  status            EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category VehicleCategory @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  driverAssignments VehicleDriverAssignment[]
  transportAssignments StudentTransportAssignment[]

  @@unique([tenantId, registrationNumber], name: "uniqueVehicleRegPerTenant")
  @@unique([id, tenantId], name: "vehicle_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("vehicles")
}

/// Driver-to-vehicle assignments
model VehicleDriverAssignment {
  id            String   @id @default(uuid())
  tenantId      String
  vehicleId     String
  driverId      String   // references Teacher.id where employeeType = driver
  isPrimaryDriver Boolean @default(true)
  assignedDate  DateTime @default(now())
  endDate       DateTime?
  status        EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  driver  Teacher @relation(fields: [driverId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, vehicleId, driverId], name: "uniqueDriverVehicleAssignment")
  @@unique([id, tenantId], name: "vehicle_driver_assignment_tenant_identity")
  @@index([tenantId, vehicleId])
  @@index([tenantId, driverId])
  @@map("vehicle_driver_assignments")
}

/// Pickup points with GPS coordinates
model PickupPoint {
  id        String   @id @default(uuid())
  tenantId  String
  name      String   // e.g., "Main Gate", "Bus Stop A"
  address   String?
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  transportAssignments StudentTransportAssignment[]

  @@unique([tenantId, name], name: "uniquePickupPointPerTenant")
  @@unique([id, tenantId], name: "pickup_point_tenant_identity")
  @@index([tenantId])
  @@map("pickup_points")
}

/// Student transport assignments — links a student to a pickup point, vehicle, and category
model StudentTransportAssignment {
  id            String   @id @default(uuid())
  tenantId      String
  enrollmentId  String
  pickupPointId String
  vehicleId     String?
  categoryId    String?
  isActive      Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  pickupPoint PickupPoint      @relation(fields: [pickupPointId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  vehicle    Vehicle?          @relation(fields: [vehicleId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  category   VehicleCategory?  @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, enrollmentId], name: "uniqueTransportPerEnrollment")
  @@unique([id, tenantId], name: "student_transport_assignment_tenant_identity")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, pickupPointId])
  @@index([tenantId, vehicleId])
  @@index([tenantId, categoryId])
  @@map("student_transport_assignments")
}

// ---------------- Attendance ----------------
/// Represents a single attendance-taking event for a section.
/// Supports period_wise (with period + subject) and shift_wise (with shift name) modes.
/// Context type (regular, exam, event, etc.) is flexible and user-selectable.
model AttendanceSession {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  sectionId       String
  takenById       String?  // teacher/user who marked attendance

  date            DateTime @db.Date

  // Context — what kind of session this is
  contextType     AttendanceContextType @default(regular)
  contextName     String?  // e.g. "Science Fair 2026", "Mid Term Maths"
  contextRefId    String?  // polymorphic ref to exam/event/etc.
  contextRefType  String?  // "exam" | "exam_paper" | "event" | etc.

  // Period-wise fields (null for shift_wise)
  periodId        String?
  sectionSubjectId String?

  // Shift-wise fields (null for period_wise)
  shift           String?  // "Morning", "Afternoon", etc.

  notes           String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  academicYear  AcademicYear     @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section       Section          @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  takenBy       User?            @relation(fields: [takenById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  period        TimetablePeriod? @relation(fields: [periodId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  sectionSubject SectionSubject? @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  marks AttendanceMark[]

  @@unique([tenantId, sectionId, date, periodId, shift, contextType], name: "uniqueAttendanceSession")
  @@unique([id, tenantId], name: "attendance_session_tenant_identity")
  @@index([tenantId, sectionId, date])
  @@index([tenantId, academicYearId])
  @@index([tenantId, takenById])
  @@map("attendance_sessions")
}

model AttendanceMark {
  id           String           @id @default(uuid())
  tenantId     String
  sessionId    String
  enrollmentId String
  status       AttendanceStatus @default(present)
  remarks      String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  session    AttendanceSession @relation(fields: [sessionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, sessionId, enrollmentId], name: "uniqueAttendanceMark")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, sessionId])
  @@map("attendance_marks")
}

// ---------------- Parents (domain + optional login) ----------------
model Parent {
  id       String  @id @default(uuid())
  tenantId String
  userId   String? @unique

  fullName      String
  phone         String?
  email         String?
  relation      String // Father / Mother / Guardian
  aadhaarNumber String?
  occupation    String?

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user   User?  @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  students StudentParent[]

  @@unique([userId, tenantId], name: "parent_user_tenant_unique")
  @@unique([id, tenantId], name: "parent_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@map("parents")
}

model StudentParent {
  id        String  @id @default(uuid())
  tenantId  String
  studentId String
  parentId  String
  isPrimary Boolean @default(false)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  student Student @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  parent  Parent  @relation(fields: [parentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, studentId, parentId], name: "uniqueStudentParent")
  @@index([tenantId, studentId])
  @@index([tenantId, parentId])
  @@map("student_parents")
}

// ---------------- Exams / Marks / Grading ----------------
/// Admin-defined exam blueprint (e.g., "Quarterly 2026", "Weekly Test 3")
/// Defines the high-level exam type, date range, and target audience.
model Exam {
  id             String @id @default(uuid())
  tenantId       String
  academicYearId String

  name        String     // "Quarterly 2026", "Weekly Test 3"
  description String?
  examType    ExamType   // weekly / quarterly / half_yearly / annually
  status      ExamStatus @default(draft)
  startDate   DateTime   // overall start date of the exam period
  endDate     DateTime   // overall end date of the exam period

  // Source: "admin" for admin-released exams, "custom" for teacher-created local exams
  source String @default("admin")

  gradingScaleId String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  academicYear AcademicYear  @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  // NoAction (not SetNull) preserves the required tenantId. Admin must
  // detach the grading scale from the exam before deleting the scale.
  gradingScale GradingScale? @relation(fields: [gradingScaleId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)

  // Target audience: which grades and sections this exam is released for
  targetGrades    ExamTargetGrade[]
  targetSections  ExamTargetSection[]

  // Scheduled exam papers (per subject, per section)
  schedules ExamSchedule[]

  @@unique([tenantId, academicYearId, name], name: "uniqueExamNamePerYear")
  @@unique([id, tenantId], name: "exam_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, status])
  @@map("exams")
}

/// Target grade for an exam (admin-defined audience)
model ExamTargetGrade {
  id       String @id @default(uuid())
  tenantId String
  examId   String
  gradeId  String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  exam   Exam   @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  grade  Grade  @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, examId, gradeId], name: "uniqueExamTargetGrade")
  @@unique([id, tenantId], name: "exam_target_grade_tenant_identity")
  @@index([tenantId, examId])
  @@index([tenantId, gradeId])
  @@map("exam_target_grades")
}

/// Target section for an exam (admin-defined audience)
model ExamTargetSection {
  id        String @id @default(uuid())
  tenantId  String
  examId    String
  sectionId String

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  exam    Exam    @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, examId, sectionId], name: "uniqueExamTargetSection")
  @@unique([id, tenantId], name: "exam_target_section_tenant_identity")
  @@index([tenantId, examId])
  @@index([tenantId, sectionId])
  @@map("exam_target_sections")
}

/// Exam schedule — per-section scheduling of the exam
/// Created by the Section In-Charge (teacher) for their section.
/// For admin-released exams, schedules are derived from the exam blueprint.
/// For custom exams, the teacher creates this directly.
model ExamSchedule {
  id        String @id @default(uuid())
  tenantId  String
  examId    String?  // null for custom (teacher-created) exams
  sectionId String

  name        String             // "Quarterly 2026 - Section A", or custom exam name
  description String?
  status      ExamScheduleStatus @default(pending)
  startDate   DateTime           // overall start date for this section's exam period
  endDate     DateTime           // overall end date for this section's exam period

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  exam    Exam?   @relation(fields: [examId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  // Subject-wise exam papers scheduled for this section
  papers ExamSchedulePaper[]

  @@unique([id, tenantId], name: "exam_schedule_tenant_identity")
  @@index([tenantId, examId])
  @@index([tenantId, sectionId])
  @@map("exam_schedules")
}

/// Individual subject paper within a schedule
/// Each row in the scheduling table that the teacher edits.
model ExamSchedulePaper {
  id               String @id @default(uuid())
  tenantId         String
  scheduleId       String
  sectionSubjectId String

  examDate        DateTime
  startTime       Int      // minutes from midnight (e.g., 540 = 9:00 AM)
  endTime         Int      // minutes from midnight (e.g., 600 = 10:00 AM)
  durationMinutes Int?
  room            String?  // assigned classroom/location
  inChargeId      String?  // teacher assigned as invigilator

  maxMarks        Int
  passMarks       Int

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  schedule       ExamSchedule   @relation(fields: [scheduleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject SectionSubject @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  inCharge       Teacher?       @relation(fields: [inChargeId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  marks ExamMark[]

  @@unique([tenantId, scheduleId, sectionSubjectId], name: "uniquePaperPerScheduleSubject")
  @@unique([id, tenantId], name: "exam_schedule_paper_tenant_identity")
  @@index([tenantId, scheduleId])
  @@index([tenantId, sectionSubjectId])
  @@index([tenantId, inChargeId])
  @@map("exam_schedule_papers")
}

model ExamMark {
  id           String @id @default(uuid())
  tenantId     String
  examPaperId  String
  enrollmentId String

  marksObtained Float?  // nullable; auto-calculated from breakup sum if breakup is provided
  isAbsent      Boolean @default(false)
  breakup       Json?   // free JSON object e.g. {"topics":[{"topic":"Algebra","marks":15}]}
  remarks       String?
  gradeLabel    String? // snapshot; can also be derived from grading scale

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  examPaper  ExamSchedulePaper @relation(fields: [examPaperId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, examPaperId, enrollmentId], name: "uniqueMarkPerStudentPerPaper")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, examPaperId])
  @@map("exam_marks")
}

model GradingScale {
  id       String @id @default(uuid())
  tenantId String
  name     String // "CBSE Scale", "GPA Scale"

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bands  GradingBand[]
  exams  Exam[]

  @@unique([tenantId, name], name: "uniqueGradingScalePerTenant")
  @@unique([id, tenantId], name: "grading_scale_tenant_identity")
  @@index([tenantId])
  @@map("grading_scales")
}

model GradingBand {
  id       String @id @default(uuid())
  tenantId String
  scaleId  String

  minMarks  Float // inclusive lower bound (percentage or absolute)
  maxMarks  Float // inclusive upper bound
  grade     String // "A+", "B", etc.
  gpa       Float?
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  scale  GradingScale @relation(fields: [scaleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, scaleId, grade], name: "uniqueGradeInScale")
  @@index([tenantId, scaleId])
  @@map("grading_bands")
}

// ---------------- Holidays / Calendar ----------------
model Holiday {
  id             String  @id @default(uuid())
  tenantId       String
  academicYearId String?

  date    DateTime
  name    String
  type    HolidayType @default(school)
  fullDay Boolean     @default(true)
  remarks String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // NoAction (not SetNull) preserves the required tenantId. Admin must
  // clear academicYearId from holidays before deleting an AcademicYear.
  academicYear AcademicYear? @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)

  @@unique([tenantId, date, name], name: "uniqueHolidayPerTenantDate")
  @@index([tenantId, date])
  @@index([tenantId, academicYearId])
  @@map("holidays")
}

// ---------------- Students ----------------
model Student {
  id       String @id @default(uuid())
  tenantId String

  admissionNumber String? // school's internal admission/roll identifier

  firstName   String
  middleName  String?
  lastName    String
  dateOfBirth DateTime
  gender      Gender

  aadhaarNumber       String?
  casteCategory       String?
  subCaste            String?
  religion            String?
  motherTongue        String?
  bloodGroup          String?
  nationality         String  @default("Indian")
  identificationMarks String?

  // Parent / family details (flat fields for quick read; canonical parent records live in Parent model)
  fatherName          String?
  fatherOccupation    String?
  fatherPhone         String?
  fatherAadhaar       String?
  motherName          String?
  motherOccupation    String?
  motherPhone         String?
  motherAadhaar       String?
  guardianName        String?
  guardianRelation    String?
  guardianContact     String?
  guardianOccupation  String?
  guardianAadhaar     String?

  classApplyingFor      String?
  mediumOfInstruction   String?
  previousSchoolName    String?
  previousClassAttended String?
  transferCertificateNo String?
  dateOfIssueTC         DateTime?
  modeOfTransport       String?

  permanentAddress String?
  state            String?
  pincode          String?

  feePaymentMode        String?
  bankAccountDetails    String?
  midDayMealEligibility Boolean @default(false)

  // CURRENT SNAPSHOT (keep for fast read; canonical source is active StudentEnrollment)
  gradeId   String
  sectionId String

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  grade   Grade   @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  enrollments StudentEnrollment[]
  parents     StudentParent[] // canonical parent links live here; documents live in Upload

  @@unique([tenantId, aadhaarNumber], name: "student_aadhaar_per_tenant")
  @@unique([tenantId, admissionNumber], name: "student_admission_per_tenant")
  @@unique([id, tenantId], name: "student_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, gradeId])
  @@index([tenantId, sectionId])
  @@index([tenantId, status])
  @@map("students")
}

// ---------------- Inventory ----------------
model InventoryCategory {
  id                    String   @id @default(uuid())
  tenantId              String
  inventoryCategoryName String
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items  InventoryItem[]

  @@unique([id, tenantId], name: "inventory_category_tenant_identity")
  @@index([tenantId])
  @@map("inventory_categories")
}

model InventoryItem {
  id                String   @id @default(uuid())
  tenantId          String
  inventoryItemName String
  description       String?
  categoryId        String?
  stockAvailable    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // NoAction (not SetNull) preserves the required tenantId. Admin must
  // clear categoryId from items before deleting an InventoryCategory.
  category    InventoryCategory? @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)
  adjustments StockAdjustment[]

  @@unique([id, tenantId], name: "inventory_item_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("inventory_items")
}

model StockAdjustment {
  id               String  @id @default(uuid())
  tenantId         String
  itemId           String?
  adjustmentAmount Int
  reason           String?
  borrowerName     String?
  borrowerId       String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  item   InventoryItem? @relation(fields: [itemId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([tenantId, itemId])
  @@map("stock_adjustments")
}

// ---------------- Auth utils & uploads ----------------
model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiredAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("token_blacklist")
}

model Upload {
  id           String @id @default(uuid())
  tenantId     String
  entityType   String // canonical values: 'student' | 'teacher' | 'parent' | 'user' | 'tenant' | 'exam'
  entityId     String
  documentType String // e.g. 'aadhaar', 'photo', 'tc', 'birth_certificate', 'caste_certificate', 'marksheet', 'income_certificate'
  fileUrl      String

  createdById String?
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType])
  @@index([tenantId, entityId])
  @@index([tenantId, entityType, entityId])
  @@map("uploads")
}

// ---------------- Fee Management ----------------
/// Configurable fee categories per tenant (e.g., Tuition Fee, Transport Fee, Lab Fee)
model FeeHead {
  id          String  @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isOptional  Boolean @default(false)
  sortOrder   Int     @default(0)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  sectionFeeHeads SectionFeeHead[]
  studentFeeHeads StudentFeeHead[]
  feePayments     FeePayment[]

  @@unique([tenantId, name], name: "uniqueFeeHeadPerTenant")
  @@unique([id, tenantId], name: "fee_head_tenant_identity")
  @@index([tenantId])
  @@map("fee_heads")
}

/// Fee configuration per section per academic year
model SectionFee {
  id             String   @id @default(uuid())
  tenantId       String
  sectionId      String
  academicYearId String

  // Overrides tenant defaultTermCount if needed
  termCount Int @default(1)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  section      Section      @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  feeHeads SectionFeeHead[]
  terms    FeeTerm[]

  @@unique([tenantId, sectionId, academicYearId], name: "uniqueSectionFeePerYear")
  @@unique([id, tenantId], name: "section_fee_tenant_identity")
  @@index([tenantId, sectionId])
  @@index([tenantId, academicYearId])
  @@map("section_fees")
}

/// Per-head amount for a section's fee configuration
model SectionFeeHead {
  id           String  @id @default(uuid())
  tenantId     String
  sectionFeeId String
  feeHeadId    String
  amount       Decimal @db.Decimal(10, 2)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sectionFee SectionFee @relation(fields: [sectionFeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  feeHead    FeeHead    @relation(fields: [feeHeadId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, sectionFeeId, feeHeadId], name: "uniqueSectionFeeHead")
  @@unique([id, tenantId], name: "section_fee_head_tenant_identity")
  @@index([tenantId, sectionFeeId])
  @@index([tenantId, feeHeadId])
  @@map("section_fee_heads")
}

/// Terms for a section's fee in an academic year (e.g., Term 1, Term 2)
model FeeTerm {
  id           String   @id @default(uuid())
  tenantId     String
  sectionFeeId String
  name         String
  dueDate      DateTime
  sortOrder    Int      @default(0)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sectionFee SectionFee @relation(fields: [sectionFeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  payments FeePayment[]

  @@unique([tenantId, sectionFeeId, name], name: "uniqueFeeTermPerSectionFee")
  @@unique([id, tenantId], name: "fee_term_tenant_identity")
  @@index([tenantId, sectionFeeId])
  @@map("fee_terms")
}

/// Per-student fee assignment linked to their enrollment
model StudentFee {
  id           String   @id @default(uuid())
  tenantId     String
  enrollmentId String

  allocationMethod FeeAllocationMethod @default(equal)

  // When auto: derived from SectionFee; when manual: set explicitly
  totalActualFee     Decimal @db.Decimal(10, 2)
  totalNegotiatedFee Decimal @db.Decimal(10, 2)

  // Discount info
  discountType  DiscountType?
  discountValue Decimal? @db.Decimal(10, 2) // percentage or fixed amount
  discountReason String?

  // JSON: per-head discount/waiver overrides
  // e.g., {"feeHeadId": {"discountPercentage": 25}} or {"feeHeadId": {"waivedAmount": 500}}
  headWiseDiscounts Json?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  feeHeads StudentFeeHead[]
  payments FeePayment[]

  @@unique([enrollmentId, tenantId], name: "uniqueStudentFeePerEnrollment")
  @@unique([id, tenantId], name: "student_fee_tenant_identity")
  @@index([tenantId, enrollmentId])
  @@map("student_fees")
}

/// Per-head breakdown for a student's fee
model StudentFeeHead {
  id              String  @id @default(uuid())
  tenantId        String
  studentFeeId    String
  feeHeadId       String
  actualAmount    Decimal @db.Decimal(10, 2)
  negotiatedAmount Decimal @db.Decimal(10, 2)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  studentFee StudentFee @relation(fields: [studentFeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  feeHead    FeeHead    @relation(fields: [feeHeadId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, studentFeeId, feeHeadId], name: "uniqueStudentFeeHead")
  @@unique([id, tenantId], name: "student_fee_head_tenant_identity")
  @@index([tenantId, studentFeeId])
  @@index([tenantId, feeHeadId])
  @@map("student_fee_heads")
}

/// Individual payment records
model FeePayment {
  id           String        @id @default(uuid())
  tenantId     String
  studentFeeId String
  termId       String?
  feeHeadId    String?       // null means payment is for the whole fee (not head-specific)

  amountPaid    Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime
  paymentMethod PaymentMethod
  transactionId String?       // receipt/transaction/cheque number
  status        PaymentStatus @default(paid)
  remarks       String?

  collectedById String?       // user who collected the payment

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  studentFee  StudentFee  @relation(fields: [studentFeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  term        FeeTerm?    @relation(fields: [termId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  feeHead     FeeHead?    @relation(fields: [feeHeadId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  collectedBy User?       @relation(fields: [collectedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  refunds FeeRefund[]

  @@unique([id, tenantId], name: "fee_payment_tenant_identity")
  @@index([tenantId, studentFeeId])
  @@index([tenantId, termId])
  @@index([tenantId, paymentDate])
  @@index([tenantId, collectedById])
  @@map("fee_payments")
}

/// Refund/adjustment tracking for payments
model FeeRefund {
  id            String   @id @default(uuid())
  tenantId      String
  paymentId     String
  amount        Decimal  @db.Decimal(10, 2)
  reason        String
  refundDate    DateTime @default(now())
  processedById String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  payment     FeePayment  @relation(fields: [paymentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  processedBy User?       @relation(fields: [processedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "fee_refund_tenant_identity")
  @@index([tenantId, paymentId])
  @@map("fee_refunds")
}

// ─── Store Module ─────────────────────────────────────────────────────────────

/// Categories for store products (e.g., Accessories, Books, Uniforms)
model StoreCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products StoreProduct[]

  @@unique([id, tenantId], name: "store_category_tenant_identity")
  @@index([tenantId, name])
  @@map("store_categories")
}

/// Individual products available in the store
model StoreProduct {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String
  name        String
  description String?
  basePrice   Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  // Section applicability
  isGeneral     Boolean @default(true) // true = available to all sections
  stockQuantity Int     @default(0)    // available stock count

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category StoreCategory  @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  sectionAssignments StoreProductSection[]
  kitItems           StoreKitItem[]
  orderItems         StoreOrderItem[]
  pendingItems       StorePendingItem[]
  returns            StoreReturn[]

  @@unique([id, tenantId], name: "store_product_tenant_identity")
  @@index([tenantId, categoryId])
  @@index([tenantId, name])
  @@map("store_products")
}

/// Product-to-section assignments (only when isGeneral = false)
model StoreProductSection {
  id        String   @id @default(uuid())
  tenantId  String
  productId String
  sectionId String
  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product StoreProduct @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section      @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, productId, sectionId], name: "uniqueProductSection")
  @@unique([id, tenantId], name: "store_product_section_tenant_identity")
  @@index([tenantId, productId])
  @@index([tenantId, sectionId])
  @@map("store_product_sections")
}

/// Kits — templates/groups of products (NOT stock items)
/// A kit is just a template. When added to cart, it expands into individual products.
model StoreKit {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  totalPrice  Decimal  @db.Decimal(10, 2) @default(0) // pre-calculated sum of all kit items
  isActive    Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  items      StoreKitItem[]
  sections   StoreKitSection[]
  orderItems StoreOrderItem[]

  @@unique([id, tenantId], name: "store_kit_tenant_identity")
  @@index([tenantId])
  @@map("store_kits")
}

/// Items within a kit (snapshotted from products at kit creation time)
model StoreKitItem {
  id           String   @id @default(uuid())
  tenantId     String
  kitId        String
  productId    String?  // optional reference back to product
  productName  String   // SNAPSHOTTED from product name
  categoryName String   // SNAPSHOTTED from category name
  unitPrice    Decimal  @db.Decimal(10, 2) // SNAPSHOTTED from product's basePrice
  quantity     Int
  totalPrice   Decimal  @db.Decimal(10, 2) // pre-calculated: unitPrice × quantity

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  kit     StoreKit     @relation(fields: [kitId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  product StoreProduct? @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "store_kit_item_tenant_identity")
  @@index([tenantId, kitId])
  @@map("store_kit_items")
}

/// Which sections a kit is available for
model StoreKitSection {
  id        String   @id @default(uuid())
  tenantId  String
  kitId     String
  sectionId String
  createdAt DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  kit     StoreKit @relation(fields: [kitId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section  @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, kitId, sectionId], name: "uniqueKitSection")
  @@unique([id, tenantId], name: "store_kit_section_tenant_identity")
  @@index([tenantId, kitId])
  @@index([tenantId, sectionId])
  @@map("store_kit_sections")
}

/// Orders placed by admin on behalf of students or external customers
model StoreOrder {
  id             String   @id @default(uuid())
  tenantId       String
  enrollmentId   String?  // null for external (non-student) customers
  academicYearId String?
  orderDate      DateTime @default(now())

  // Pricing breakdown
  totalAmount     Decimal  @db.Decimal(10, 2) // final amount after discount
  actualTotalAmount Decimal @db.Decimal(10, 2) // total before any discount
  discountAmount  Decimal  @db.Decimal(10, 2) @default(0) // total discount applied
  offeredAmount   Decimal? @db.Decimal(10, 2) // what the user offered to pay (if different)

  // Customer info (for non-student customers)
  customerName  String?
  customerPhone String?
  customerType  String   @default("student") // "student" | "external"

  status  String   @default("confirmed") // confirmed | partially_delivered | delivered | cancelled | collected
  remarks String?

  // Payment info
  paymentMethod  String? // cash | card | upi | etc.
  transactionId  String? // receipt/transaction number
  paymentMode    String? // full | partial

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  enrollment   StudentEnrollment? @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  academicYear AcademicYear?      @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  createdBy    User?             @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  items StoreOrderItem[]
  dues  StoreDue[]

  @@unique([id, tenantId], name: "store_order_tenant_identity")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, academicYearId])
  @@map("store_orders")
}

/// Items within an order (snapshotted at order time)
model StoreOrderItem {
  id          String   @id @default(uuid())
  tenantId    String
  orderId     String
  productId   String?  // if individual product
  kitId       String?  // if kit was ordered
  productName String   // SNAPSHOTTED
  unitPrice   Decimal  @db.Decimal(10, 2) // SNAPSHOTTED
  quantity    Int
  totalPrice  Decimal  @db.Decimal(10, 2) // pre-calculated

  // Kit grouping: items from the same kit share a reference ID
  kitReferenceId String? // groups items that came from the same kit expansion

  // Return/exchange support
  isReturned Boolean   @default(false)
  returnedAt DateTime?

  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  order   StoreOrder   @relation(fields: [orderId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  product StoreProduct? @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  kit     StoreKit?    @relation(fields: [kitId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  pendingItems StorePendingItem[]
  returns     StoreReturn[]

  @@unique([id, tenantId], name: "store_order_item_tenant_identity")
  @@index([tenantId, orderId])
  @@map("store_order_items")
}

/// Pending fulfillment items (when items are out of stock at distribution time)
model StorePendingItem {
  id          String   @id @default(uuid())
  tenantId    String
  orderItemId String
  productId   String?
  productName String   // SNAPSHOTTED
  quantity    Int
  status      String   @default("pending") // pending | collected
  collectedAt DateTime?

  // Payment status for pending items
  isPaid  Boolean   @default(false)
  paidAt  DateTime?

  createdById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderItem StoreOrderItem @relation(fields: [orderItemId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  product   StoreProduct?  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  createdBy User?          @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "store_pending_item_tenant_identity")
  @@index([tenantId, orderItemId])
  @@index([tenantId, status])
  @@map("store_pending_items")
}

/// Dues — when a customer pays less than the total bill amount
model StoreDue {
  id          String   @id @default(uuid())
  tenantId    String
  orderId     String
  enrollmentId String? // null for external customers

  // Customer info
  customerName  String
  customerPhone String?
  customerType  String   @default("student") // "student" | "external"

  totalDueAmount Decimal  @db.Decimal(10, 2) // total amount due
  paidAmount     Decimal  @db.Decimal(10, 2) @default(0) // amount paid so far
  status         String   @default("pending") // pending | partially_paid | settled | written_off

  remarks String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  order      StoreOrder        @relation(fields: [orderId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment? @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  createdBy  User?             @relation("createdStoreDues", fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  updatedBy  User?             @relation("updatedStoreDues", fields: [updatedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  payments StoreDuePayment[]

  @@unique([id, tenantId], name: "store_due_tenant_identity")
  @@index([tenantId, orderId])
  @@index([tenantId, status])
  @@map("store_dues")
}

/// Payments made against a due
model StoreDuePayment {
  id            String   @id @default(uuid())
  tenantId      String
  dueId         String
  amount        Decimal  @db.Decimal(10, 2)
  paymentDate   DateTime @default(now())
  paymentMethod String?  // cash | card | upi | etc.
  transactionId String?  // receipt/transaction number
  remarks       String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  due    StoreDue @relation(fields: [dueId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  createdBy User? @relation("createdStoreDuePayments", fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "store_due_payment_tenant_identity")
  @@index([tenantId, dueId])
  @@map("store_due_payments")
}

/// Returns/exchanges — when a customer returns a product from an order
model StoreReturn {
  id          String   @id @default(uuid())
  tenantId    String
  orderItemId String
  productId   String?
  productName String   // SNAPSHOTTED
  quantity    Int
  refundAmount Decimal  @db.Decimal(10, 2) // amount refunded for this return
  reason      String?
  returnedAt  DateTime @default(now())

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orderItem StoreOrderItem @relation(fields: [orderItemId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  product   StoreProduct?  @relation(fields: [productId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  createdBy User?          @relation("createdStoreReturns", fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "store_return_tenant_identity")
  @@index([tenantId, orderItemId])
  @@map("store_returns")
}

// ---------------- Payroll Module ----------------

/// Master list of salary component types (e.g., Basic Salary, HRA, Special Allowance)
model SalaryComponent {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  type        String   @default("earning") // "earning" | "deduction"
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdBy User? @relation("createdSalaryComponents", fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  updatedBy User? @relation("updatedSalaryComponents", fields: [updatedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  compensationComponents CompensationComponent[]

  @@unique([tenantId, name], name: "uniqueSalaryComponentPerTenant")
  @@unique([id, tenantId], name: "salary_component_tenant_identity")
  @@index([tenantId])
  @@map("salary_components")
}

/// Active compensation profile per employee (teacher)
model EmployeeCompensation {
  id            String   @id @default(uuid())
  tenantId      String
  employeeId    String   // references Teacher.id
  effectiveFrom DateTime // mandatory effective from date
  totalAmount   Decimal  @db.Decimal(12, 2) @default(0) // auto-calculated sum of components

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Teacher @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  createdBy User? @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  updatedBy User? @relation("updatedEmployeeCompensation", fields: [updatedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  components CompensationComponent[]
  history    CompensationHistory[]

  @@unique([employeeId, tenantId], name: "oneCompensationPerEmployee")
  @@unique([id, tenantId], name: "employee_compensation_tenant_identity")
  @@index([tenantId, employeeId])
  @@map("employee_compensations")
}

/// Individual component values within a compensation profile
model CompensationComponent {
  id                String  @id @default(uuid())
  tenantId          String
  compensationId    String
  salaryComponentId String
  value             Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  compensation   EmployeeCompensation @relation(fields: [compensationId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  salaryComponent SalaryComponent     @relation(fields: [salaryComponentId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, compensationId, salaryComponentId], name: "uniqueCompComponent")
  @@unique([id, tenantId], name: "compensation_component_tenant_identity")
  @@index([tenantId, compensationId])
  @@map("compensation_components")
}

/// Historical log of compensation changes (appended, never overwritten)
model CompensationHistory {
  id             String   @id @default(uuid())
  tenantId       String
  employeeId     String
  compensationId String?  // reference to the snapshot
  effectiveFrom  DateTime
  totalAmount    Decimal  @db.Decimal(12, 2)
  components     Json     // full snapshot of components at that time
  changedById    String?
  changedAt      DateTime @default(now())

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee     Teacher             @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  compensation EmployeeCompensation? @relation(fields: [compensationId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  changedBy    User?               @relation(fields: [changedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "compensation_history_tenant_identity")
  @@index([tenantId, employeeId])
  @@index([tenantId, changedAt])
  @@map("compensation_history")
}

/// Payroll batch — monthly payroll run
model PayrollBatch {
  id            String   @id @default(uuid())
  tenantId      String
  month         Int      // 1-12
  year          Int
  status        String   @default("draft") // draft | processing | completed | cancelled
  processedAt   DateTime?
  processedById String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdBy  User? @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  processedBy User? @relation("processedPayrollBatch", fields: [processedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  records PayrollRecord[]

  @@unique([tenantId, month, year], name: "uniqueBatchPerMonth")
  @@unique([id, tenantId], name: "payroll_batch_tenant_identity")
  @@index([tenantId, month, year])
  @@map("payroll_batches")
}

/// Individual payroll records within a batch
model PayrollRecord {
  id            String   @id @default(uuid())
  tenantId      String
  batchId       String
  employeeId    String
  actualSalary  Decimal  @db.Decimal(12, 2) // read-only from active compensation
  paidAmount    Decimal  @db.Decimal(12, 2) // editable input
  status        String   @default("pending") // pending | completed | cancelled
  paymentMethod String   @default("cash")

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  batch    PayrollBatch  @relation(fields: [batchId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  employee Teacher       @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  createdBy User?        @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, batchId, employeeId], name: "uniqueRecordPerBatchEmployee")
  @@unique([id, tenantId], name: "payroll_record_tenant_identity")
  @@index([tenantId, batchId])
  @@index([tenantId, employeeId])
  @@map("payroll_records")
}

// ---------------- Accounts / Ledger Module ----------------

/// Categories for ledger transactions (e.g., For Inventory, For Infrastructure, etc.)
model AccountCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  transactions AccountTransaction[]

  @@unique([id, tenantId], name: "account_category_tenant_identity")
  @@index([tenantId])
  @@map("account_categories")
}

/// Individual ledger entries — debit or credit against a category
model AccountTransaction {
  id              String          @id @default(uuid())
  tenantId        String
  categoryId      String
  type            TransactionType // debit or credit
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  transactionDate DateTime        @default(now())

  // Who is this transaction for?
  partyType   String?  // "teacher" | "student" | "staff" | "vendor" | "other"
  partyId     String?  // ID of teacher/student/staff (null for vendors/other)
  partyName   String?  // Denormalized name for display (required for vendors/other)

  // Polymorphic reference for future integration with Fee, Salary, etc.
  referenceType String? // "fee_payment" | "salary" | etc.
  referenceId   String?

  // Soft-delete / void for audit trail
  isVoided   Boolean   @default(false)
  voidReason String?
  voidedAt   DateTime?
  voidedById String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category AccountCategory @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  createdBy User?          @relation(fields: [createdById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  voidedBy  User?          @relation("voidedAccountTransaction", fields: [voidedById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "account_transaction_tenant_identity")
  @@index([tenantId, categoryId])
  @@index([tenantId, transactionDate])
  @@index([tenantId, referenceType, referenceId])
  @@index([tenantId, partyType, partyId])
  @@map("account_transactions")
}
