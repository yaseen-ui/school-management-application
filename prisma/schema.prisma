// ---------------- Core: Tenants, Users, Roles ----------------
model Tenant {
  id               String           @id @default(uuid())
  schoolName       String
  contactAddress   Json?
  contactPhone     String?
  contactEmail     String?
  subscriptionPlan SubscriptionPlan @default(free)
  domain           String?          @unique
  logo             String?
  caption          String?
  defaultTermCount Int      @default(1) // default number of fee terms for this institution

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relations
  users               User[]
  roles               Role[]
  courses             Course[]
  grades              Grade[]
  sections            Section[]
  subjects            Subject[]
  sectionSubjects     SectionSubject[]
  students            Student[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  stockAdjustments    StockAdjustment[]
  uploads             Upload[]

  // runtime academics
  academicYears              AcademicYear[]
  enrollments                StudentEnrollment[]
  teachers                   Teacher[]
  teacherQualifications      TeacherQualification[]
  teacherEmploymentHistory   TeacherEmploymentHistory[]
  teacherAssignments         TeacherAssignment[]
  teacherCapabilities        TeacherCapability[]
  timetableStructures        TimetableStructure[]
  timetablePeriods           TimetablePeriod[]
  timetableEntries           TimetableEntry[]
  attendanceTypes            AttendanceType[]
  attendanceSessions         AttendanceSession[]
  studentEnrollmentElectives StudentEnrollmentElective[]
  attendanceMarks            AttendanceMark[]

  // parents
  parents        Parent[]
  studentParents StudentParent[]

  // exams & grading
  exams               Exam[]
  examTargetGrades    ExamTargetGrade[]
  examTargetSections  ExamTargetSection[]
  examSchedules       ExamSchedule[]
  examSchedulePapers  ExamSchedulePaper[]
  examMarks           ExamMark[]
  gradingScales       GradingScale[]
  gradingBands        GradingBand[]

  // calendar
  holidays            Holiday[]
  holidayCategories   HolidayCategory[]
  tenantHolidayRules  TenantHolidayRule[]

  // infrastructure
  buildings Building[]
  floors    Floor[]
  rooms     Room[]

  // teacher availability
  teacherAvailabilities TeacherAvailability[]

  // fee management
  feeHeads        FeeHead[]
  sectionFees     SectionFee[]
  sectionFeeHeads SectionFeeHead[]
  feeTerms        FeeTerm[]
  studentFees     StudentFee[]
  studentFeeHeads StudentFeeHead[]
  feePayments     FeePayment[]
  feeRefunds      FeeRefund[]

  // store
  storeCategories      StoreCategory[]
  storeProducts        StoreProduct[]
  storeProductSections StoreProductSection[]
  storeKits            StoreKit[]
  storeKitItems        StoreKitItem[]
  storeKitSections     StoreKitSection[]
  storeOrders          StoreOrder[]
  storeOrderItems      StoreOrderItem[]
  storePendingItems    StorePendingItem[]
  storeDues            StoreDue[]
  storeDuePayments     StoreDuePayment[]
  storeReturns         StoreReturn[]

  // accounts / ledger
  accountCategories    AccountCategory[]
  accountTransactions  AccountTransaction[]

  // payroll
  salaryComponents        SalaryComponent[]
  employeeCompensations   EmployeeCompensation[]
  compensationComponents  CompensationComponent[]
  compensationHistory     CompensationHistory[]
  payrollBatches          PayrollBatch[]
  payrollRecords          PayrollRecord[]

  // transportation
  vehicleCategories           VehicleCategory[]
  vehicles                    Vehicle[]
  vehicleDriverAssignments    VehicleDriverAssignment[]
  pickupPoints                PickupPoint[]
  studentTransportAssignments StudentTransportAssignment[]

  // visitor module
  visitorPurposes VisitorPurpose[]
  visitors        Visitor[]
  visitorNotifications VisitorNotification[]

  // staff attendance
  staffAttendances StaffAttendance[]
  staffAttendanceSessions StaffAttendanceSession[]

  // leave management
  leaveCategories           LeaveCategory[]
  leaveRequests             LeaveRequest[]
  leaveApprovals            LeaveApproval[]
  leaveCancellations        LeaveCancellation[]
  leaveAuditLogs            LeaveAuditLog[]
  leaveNotifications        LeaveNotification[]
  employeeLeaveBalances     EmployeeLeaveBalance[]
  leaveBalanceTransactions  LeaveBalanceTransaction[]
  employeeLeaveLossOfPays   EmployeeLeaveLossOfPay[]
  tenantLeaveConfiguration  TenantLeaveConfiguration?

  // id sequence
  idSequencePatterns IdSequencePattern[]
  idSequenceLogs     IdSequenceLog[]

  // RBAC v2
  groups Group[]

  @@map("tenants")
}

model User {
  id       String   @id @default(uuid())
  tenantId String?
  fullName String
  email    String
  password String
  userType UserType @default(tenant)

  // OTP fields (consider extracting to dedicated OtpToken table later)
  otp          String?
  otpExpiresAt DateTime?
  otpPurpose   String? // 'login' | 'password_reset' | 'first_login'
  isFirstLogin Boolean   @default(true)

  phone String?

  // RBAC v2: permission version counter (bumped when user's roles/permissions change)
  permVersion Int @default(0)

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // RBAC v2: multiple roles per user (replaces old roleId + role relation)
  userRoles UserRole[]

  // optional domain mappings
  teacher Teacher?
  parent  Parent?

  // attendance sessions taken by this user
  attendanceSessionsTaken AttendanceSession[]

  // fee management
  collectedPayments FeePayment[] // payments collected by this user
  processedRefunds  FeeRefund[]  // refunds processed by this user

  // store
  createdStoreOrders       StoreOrder[]
  createdStoreDues         StoreDue[]          @relation("createdStoreDues")
  updatedStoreDues         StoreDue[]          @relation("updatedStoreDues")
  createdStoreDuePayments  StoreDuePayment[]   @relation("createdStoreDuePayments")
  createdStoreReturns      StoreReturn[]        @relation("createdStoreReturns")
  createdStorePendingItems StorePendingItem[]

  // payroll
  createdSalaryComponents      SalaryComponent[] @relation("createdSalaryComponents")
  updatedSalaryComponents      SalaryComponent[] @relation("updatedSalaryComponents")
  createdEmployeeCompensations EmployeeCompensation[]
  updatedEmployeeCompensations EmployeeCompensation[] @relation("updatedEmployeeCompensation")
  changedCompensationHistories CompensationHistory[]
  createdPayrollBatches        PayrollBatch[]
  processedPayrollBatches      PayrollBatch[]         @relation("processedPayrollBatch")
  createdPayrollRecords        PayrollRecord[]

  // accounts
  createdAccountTransactions AccountTransaction[]
  voidedAccountTransactions  AccountTransaction[]  @relation("voidedAccountTransaction")

  // visitor module
  visitorApproved       Visitor[]                @relation("visitorApprovedBy")
  visitorCreated        Visitor[]                @relation("visitorCreatedBy")
  visitorNotifications  VisitorNotification[]
  
  @@unique([tenantId, email], name: "user_email_per_tenant")
  @@unique([email, userType], name: "user_email_per_type")
  @@unique([id, tenantId], name: "user_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  roleName    String
  description String?
  isDefault   Boolean @default(false)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  roleGroups      RoleGroup[]

  @@unique([id, tenantId], name: "role_tenant_identity")
  @@unique([tenantId, roleName], name: "uniqueRoleNamePerTenant")
  @@index([tenantId])
  @@map("roles")
}

// --- New: Canonical Permission catalog (seeded by application, not tenant-editable) ---
model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  module      String
  action      String
  scope       String?
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  @@map("permissions")
}

// --- New: Many-to-many Role ↔ Permission (tenant-scoped) ---
model RolePermission {
  roleId       String
  permissionId String
  tenantId     String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId, tenantId])
  @@map("role_permissions")
}

// --- New: Many-to-many User ↔ Role (replaces user.roleId, allows multiple roles per user) ---
model UserRole {
  userId    String
  roleId    String
  tenantId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@id([userId, roleId, tenantId])
  @@map("user_roles")
}

// --- New: Group model (organizational bucket for roles) ---
model Group {
  id          String   @id @default(uuid())
  tenantId    String
  groupName   String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  roleGroups RoleGroup[]

  @@unique([id, tenantId], name: "group_tenant_identity")
  @@unique([tenantId, groupName], name: "uniqueGroupNamePerTenant")
  @@index([tenantId])
  @@map("groups")
}

// --- New: Many-to-many Role ↔ Group ---
model RoleGroup {
  roleId    String
  groupId   String
  tenantId  String
  createdAt DateTime @default(now())

  role  Role  @relation(fields: [roleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  group Group @relation(fields: [groupId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, groupId, tenantId])
  @@map("role_groups")
}

// --- New: Audit Trail for authorization changes and critical actions ---
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  details    Json?
  ipAddress  String?
  level      String   @default("info")
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("audit_logs")
}

// ---------------- Academics: Courses, Grades, Sections, Subjects, SectionSubjects ----------------
model Course {
  id          String   @id @default(uuid())
  tenantId    String
  courseName  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  grades   Grade[]
  subjects Subject[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  @@unique([id, tenantId], name: "course_tenant_identity")
  @@index([tenantId])
  @@map("courses")
}

model Grade {
  id        String   @id @default(uuid())
  tenantId  String
  courseId  String
  gradeName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course Course @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  sections    Section[]
  students    Student[] // current snapshot
  enrollments StudentEnrollment[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  // exam target audience
  examTargetGrades ExamTargetGrade[]

  @@unique([id, tenantId], name: "grade_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, courseId])
  @@map("grades")
}

model Section {
  id             String         @id @default(uuid())
  tenantId       String
  gradeId        String
  sectionName    String
  structureId         String? // which timetable structure this section follows
  roomId              String? // dedicated classroom for this section
  sectionInChargeId   String? // teacher assigned as section in-charge

  // Attendance configuration
  attendanceMode SectionAttendanceMode @default(period_wise)
  shifts         Json?          // [{name:"Morning",sortOrder:1},{name:"Afternoon",sortOrder:2}] — only for shift_wise

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  grade     Grade               @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  structure TimetableStructure? @relation(fields: [structureId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  room      Room?               @relation(fields: [roomId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  sectionInCharge Teacher?      @relation(fields: [sectionInChargeId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  sectionSubjects SectionSubject[]
  students        Student[] // current snapshot
  enrollments     StudentEnrollment[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  // attendance sessions
  attendanceSessions AttendanceSession[]

  // fee management
  sectionFees SectionFee[]

  // store
  storeProductSections StoreProductSection[]
  storeKitSections     StoreKitSection[]

  // exam schedules
  examSchedules      ExamSchedule[]
  examTargetSections ExamTargetSection[]

  @@unique([id, tenantId], name: "section_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, gradeId])
  @@index([tenantId, structureId])
  @@index([tenantId, roomId])
  @@map("sections")
}

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  subjectName String
  courseId    String
  isCommon    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  course Course @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  sectionSubjects SectionSubject[]

  // teacher capabilities
  teacherCapabilities TeacherCapability[]

  @@unique([id, tenantId], name: "subject_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, courseId])
  @@map("subjects")
}

model SectionSubject {
id         String   @id @default(uuid())
  tenantId   String
  sectionId  String
  subjectId  String
  isElective Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  section Section @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  electiveSelections StudentEnrollmentElective[]
  examSchedulePapers ExamSchedulePaper[]
  attendanceSessions AttendanceSession[]

  @@unique([tenantId, sectionId, subjectId], name: "sectionSubjectUnique")
  @@unique([id, tenantId], name: "section_subject_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, sectionId])
  @@index([tenantId, subjectId])
  @@map("section_subjects")
}

// ---------------- Academic Year & Enrollments ----------------
model AcademicYear {
  id        String             @id @default(uuid())
  tenantId  String
  name      String // e.g., "2025-26"
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(draft)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  enrollments        StudentEnrollment[]
  teacherAssignments TeacherAssignment[]
  timetableEntries   TimetableEntry[]
  holidays            Holiday[]
  tenantHolidayRules  TenantHolidayRule[]

  exams               Exam[]
  attendanceSessions  AttendanceSession[]

  // fee management
  sectionFees SectionFee[]

  // store
  storeOrders StoreOrder[]

  // leave management
  leaveBalances EmployeeLeaveBalance[]

  // id sequence
  idSequencePatterns IdSequencePattern[]

  @@unique([tenantId, name], name: "academicYearNamePerTenant")
  @@unique([id, tenantId], name: "academic_year_tenant_identity")
  @@index([tenantId, status])
  @@map("academic_years")
}

model StudentEnrollment {
  id             String           @id @default(uuid())
  tenantId       String
  studentId      String
  academicYearId String
  gradeId        String
  sectionId      String
  rollNumber     String?
  status         EnrollmentStatus @default(active)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  student      Student      @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  grade        Grade        @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section      Section      @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  electiveSelections StudentEnrollmentElective[]
  attendanceMarks    AttendanceMark[]
  examMarks          ExamMark[]

  // fee management
  studentFee StudentFee?

  // store
  storeOrders StoreOrder[]
  storeDues   StoreDue[]

  // transportation
  transportAssignments StudentTransportAssignment[]

  // leave management
  leaveRequests LeaveRequest[]

  @@unique([tenantId, studentId, academicYearId], name: "oneEnrollmentPerYear")
  @@unique([id, tenantId], name: "student_enrollment_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, gradeId])
  @@index([tenantId, sectionId])
  @@map("student_enrollments")
}

model StudentEnrollmentElective {
  id               String   @id @default(uuid())
  tenantId         String
  enrollmentId     String
  sectionSubjectId String
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  enrollment     StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject SectionSubject    @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, enrollmentId, sectionSubjectId], name: "uniqueElectiveSelection")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, sectionSubjectId])
  @@map("student_enrollment_electives")
}

// ---------------- Teachers & Assignments ----------------
model Teacher {
  id       String  @id @default(uuid())
  tenantId String
  userId   String? @unique

  fullName     String
  email        String?
  phone        String?
  gender       Gender?
  employeeCode String?

  // Employee type (teacher by default, can be driver, clerk, etc.)
  employeeType EmployeeType @default(teacher)

  // Registration flow — invite-based staff registration
  registrationToken    String?   @unique
  registrationTokenExp DateTime?
  isRegistered         Boolean   @default(false)

  // Onboarding profile
  profilePhotoUrl   String?
  dateOfBirth       DateTime?
  dateOfJoining     DateTime?
  yearsOfExperience Float?

  // Government ID (for all non-teaching staff)
  governmentIdType   String?  // "aadhar", "pan", "voter_id", "passport"
  governmentIdNumber String?
  governmentIdUrl    String?  // GCP upload URL for ID document

  // Driver-specific fields (nullable, only for employeeType = driver)
  drivingLicenseNumber    String?
  drivingLicenseUrl       String?  // GCP upload URL
  drivingExperienceYears  Int?
  vehicleType             String?  // "bus", "van", "car", "auto"
  licenseExpiryDate       DateTime?
  medicalCertificateUrl   String?  // GCP upload URL

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  // Note: User model no longer has roleId, but this relation existed for userId. Keeping as-is.
  user   User?  @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  assignments       TeacherAssignment[]
  capabilities      TeacherCapability[]
  qualifications    TeacherQualification[]
  employmentHistory TeacherEmploymentHistory[]
  availabilities    TeacherAvailability[]
  sectionsInCharge  Section[]
  examPapersInCharge ExamSchedulePaper[]

  // payroll
  compensations      EmployeeCompensation[]
  compensationHistory CompensationHistory[]
  payrollRecords     PayrollRecord[]

  // transportation
  vehicleDriverAssignments VehicleDriverAssignment[]

  // visitor module — visitors who selected this staff as point of contact
  visitorsAsPointOfContact Visitor[]

  // staff attendance
  attendances StaffAttendance[]

  // leave management
  leaveRequests        LeaveRequest[]
  leaveBalances        EmployeeLeaveBalance[]
  leaveLossOfPays      EmployeeLeaveLossOfPay[]

  @@unique([userId, tenantId], name: "teacher_user_tenant_unique")
  @@unique([tenantId, employeeCode], name: "teacherCodePerTenant")
  @@unique([id, tenantId], name: "teacher_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("teachers")
}

model TeacherQualification {
  id                String   @id @default(uuid())
  tenantId          String
  teacherId         String
  qualificationName String // B.Sc, M.Sc, B.Ed, PhD, etc.
  specialization    String?
  institution       String?
  score             Float? // percentage or CGPA
  yearOfPassing     Int?
  documentUrl       String? // reference to Upload.fileUrl
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "teacher_qualification_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, teacherId])
  @@map("teacher_qualifications")
}

model TeacherEmploymentHistory {
  id               String    @id @default(uuid())
  tenantId         String
  teacherId        String
  organizationName String
  role             String // designation / position
  startDate        DateTime?
  endDate          DateTime?
  reasonForLeaving String?
  experienceYears  Float? // snapshot at the time of entry
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "teacher_employment_history_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, teacherId])
  @@map("teacher_employment_history")
}

model TeacherAssignment {
  id               String      @id @default(uuid())
  tenantId         String
  academicYearId   String
  teacherId        String
  sectionSubjectId String
  role             TeacherRole @default(subject_teacher)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  academicYear   AcademicYear   @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  teacher        Teacher        @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject SectionSubject @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  timetableEntries   TimetableEntry[]

  @@unique([tenantId, academicYearId, teacherId, sectionSubjectId], name: "uniqueTeacherAssignment")
  @@unique([id, tenantId], name: "teacher_assignment_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, teacherId])
  @@index([tenantId, sectionSubjectId])
  @@map("teacher_assignments")
}

// ---------------- Teacher Capabilities (what a teacher CAN teach) ----------------
model TeacherCapability {
  id        String         @id @default(uuid())
  tenantId  String
  teacherId String
  subjectId String

  // Optional scoping: null means "all courses" or "all grades"
  courseId String?
  gradeId  String?
  sectionId String?

  expertiseLevel   ExpertiseLevel @default(intermediate)
  isPrimary        Boolean        @default(false)
  priorityScore    Int            @default(50)
  canBeClassTeacher Boolean       @default(false)
  remarks          String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  subject Subject @relation(fields: [subjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  course  Course? @relation(fields: [courseId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  grade   Grade?  @relation(fields: [gradeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section Section? @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "teacher_capability_tenant_identity")
  @@index([tenantId, teacherId])
  @@index([tenantId, subjectId])
  @@index([tenantId, courseId])
  @@index([tenantId, gradeId])
  @@index([tenantId, sectionId])
  @@map("teacher_capabilities")
}

// ---------------- Teacher Availability (recurring weekly schedule) ----------------
model TeacherAvailability {
  id          String    @id @default(uuid())
  tenantId    String
  teacherId   String
  dayOfWeek   DayOfWeek
  startTime   Int       // minutes from midnight (360 = 6:00 AM)
  endTime     Int       // minutes from midnight (1080 = 6:00 PM)
  isAvailable Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, teacherId, dayOfWeek, startTime, endTime], name: "uniqueTeacherAvailabilitySlot")
  @@unique([id, tenantId], name: "teacher_availability_tenant_identity")
  @@index([tenantId, teacherId])
  @@map("teacher_availability")
}

// ---------------- Timetable Structures & Periods ----------------
model TimetableStructure {
  id          String   @id @default(uuid())
  tenantId    String
  name        String // "Primary", "Secondary", "Pre-Primary"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  periods TimetablePeriod[]
  sections Section[]

  @@unique([tenantId, name], name: "uniqueStructureNamePerTenant")
  @@unique([id, tenantId], name: "timetable_structure_tenant_identity")
  @@index([tenantId])
  @@map("timetable_structures")
}

model TimetablePeriod {
  id          String     @id @default(uuid())
  tenantId    String
  structureId String
  name        String // "P1", "P2", "LAB-1", "FULL_DAY" (sentinel for daily-mark schools)
  type        PeriodType @default(class)
  startTime   Int // minutes from midnight, 0-1439; e.g. 09:00 = 540
  endTime     Int // minutes from midnight, 0-1439; e.g. 09:45 = 585
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt


  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  structure TimetableStructure  @relation(fields: [structureId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  entries   TimetableEntry[]
  attendanceSessions AttendanceSession[]

  @@unique([tenantId, structureId, name], name: "uniquePeriodNamePerStructure")
  @@unique([id, tenantId], name: "timetable_period_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, structureId])
  @@map("timetable_periods")
}

model TimetableEntry {
  id                  String    @id @default(uuid())
  tenantId            String
  academicYearId      String
  dayOfWeek           DayOfWeek
  periodId            String
  sectionSubjectId    String
  teacherAssignmentId String?
  room                String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  academicYear      AcademicYear       @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  period            TimetablePeriod    @relation(fields: [periodId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sectionSubject    SectionSubject     @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  // NoAction (not SetNull) because the composite FK includes the required tenantId.
  // Admin must reassign or clear teacherAssignmentId before deleting a TeacherAssignment.
  teacherAssignment TeacherAssignment? @relation(fields: [teacherAssignmentId, tenantId], references: [id, tenantId], onDelete: NoAction, onUpdate: Cascade)

  @@unique([id, tenantId], name: "timetable_entry_tenant_identity")
  @@index([tenantId, academicYearId])
  @@index([tenantId, sectionSubjectId])
  @@index([tenantId, periodId])
  @@map("timetable_entries")
}

// ---------------- Infrastructure: Buildings, Floors, Rooms ----------------
model Building {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  description String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  floors Floor[]

  @@unique([id, tenantId], name: "building_tenant_identity")
  @@unique([tenantId, name], name: "uniqueBuildingNamePerTenant")
  @@index([tenantId])
  @@map("buildings")
}

model Floor {
  id          String   @id @default(uuid())
  tenantId    String
  buildingId  String
  floorNumber Int
  name        String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  building Building @relation(fields: [buildingId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  rooms    Room[]

  @@unique([id, tenantId], name: "floor_tenant_identity")
  @@unique([tenantId, buildingId, floorNumber], name: "uniqueFloorPerBuilding")
  @@index([tenantId])
  @@index([tenantId, buildingId])
  @@map("floors")
}

model Room {
  id           String       @id @default(uuid())
  tenantId     String
  floorId      String
  roomNumber   String
  roomName     String?
  roomType     RoomType     @default(classroom)
  roomCategory RoomCategory?
  capacity     Int
  status       EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  floor    Floor     @relation(fields: [floorId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  sections Section[]

  @@unique([id, tenantId], name: "room_tenant_identity")
  @@unique([tenantId, floorId, roomNumber], name: "uniqueRoomPerFloor")
  @@index([tenantId])
  @@index([tenantId, floorId])
  @@index([tenantId, status])
  @@map("rooms")
}

// ---------------- Transportation Module ----------------

/// Vehicle categories define the type and amenities of vehicles
/// e.g., "Deluxe Bus (AC, 40 seats)", "Standard Van (Non-AC, 12 seats)"
model VehicleCategory {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g., "Deluxe Bus", "Standard Van", "AC Car"
  type        VehicleCategoryType // bus, van, car, auto
  occupancy   Int      // number of people it can carry (e.g., 40, 30, 5, 10)
  amenities   VehicleAmenity[] // ac, non_ac, deluxe, standard
  description String?
  isActive    Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  vehicles Vehicle[]
  studentTransportAssignments StudentTransportAssignment[]

  @@unique([tenantId, name], name: "uniqueVehicleCategoryPerTenant")
  @@unique([id, tenantId], name: "vehicle_category_tenant_identity")
  @@index([tenantId])
  @@map("vehicle_categories")
}

/// Individual vehicles registered in the system
model Vehicle {
  id                String   @id @default(uuid())
  tenantId          String
  categoryId        String
  name              String   // e.g., "Bus 01", "Deluxe Bus A"
  registrationNumber String? // e.g., "KA-01-AB-1234"
  capacity          Int      // actual seating capacity (may differ from category occupancy)
  description       String?
  status            EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category VehicleCategory @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  driverAssignments VehicleDriverAssignment[]
  transportAssignments StudentTransportAssignment[]

  @@unique([tenantId, registrationNumber], name: "uniqueVehicleRegPerTenant")
  @@unique([id, tenantId], name: "vehicle_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@map("vehicles")
}

/// Driver-to-vehicle assignments
model VehicleDriverAssignment {
  id            String   @id @default(uuid())
  tenantId      String
  vehicleId     String
  driverId      String   // references Teacher.id where employeeType = driver
  isPrimaryDriver Boolean @default(true)
  assignedDate  DateTime @default(now())
  endDate       DateTime?
  status        EntityStatus @default(active)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  driver  Teacher @relation(fields: [driverId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, vehicleId, driverId], name: "uniqueDriverVehicleAssignment")
  @@unique([id, tenantId], name: "vehicle_driver_assignment_tenant_identity")
  @@index([tenantId, vehicleId])
  @@index([tenantId, driverId])
  @@map("vehicle_driver_assignments")
}

/// Pickup points with GPS coordinates
model PickupPoint {
  id        String   @id @default(uuid())
  tenantId  String
  name      String   // e.g., "Main Gate", "Bus Stop A"
  address   String?
  latitude  Float
  longitude Float
  isActive  Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  transportAssignments StudentTransportAssignment[]

  @@unique([tenantId, name], name: "uniquePickupPointPerTenant")
  @@unique([id, tenantId], name: "pickup_point_tenant_identity")
  @@index([tenantId])
  @@map("pickup_points")
}

/// Student transport assignments — links a student to a pickup point, vehicle, and category
model StudentTransportAssignment {
  id            String   @id @default(uuid())
  tenantId      String
  enrollmentId  String
  pickupPointId String
  vehicleId     String?
  categoryId    String?
  isActive      Boolean  @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  pickupPoint PickupPoint      @relation(fields: [pickupPointId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  vehicle    Vehicle?          @relation(fields: [vehicleId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  category   VehicleCategory?  @relation(fields: [categoryId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, enrollmentId], name: "uniqueTransportPerEnrollment")
  @@unique([id, tenantId], name: "student_transport_assignment_tenant_identity")
  @@index([tenantId, enrollmentId])
  @@index([tenantId, pickupPointId])
  @@index([tenantId, vehicleId])
  @@index([tenantId, categoryId])
  @@map("student_transport_assignments")
}

// ---------------- Attendance Types (CRUD-manageable) ----------------
model AttendanceType {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  category  String   // "shift" | "period" | "exam"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sessions AttendanceSession[]

  @@unique([tenantId, name])
  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, category])
  @@map("attendance_types")
}

// ---------------- Attendance ----------------
model AttendanceSession {
  id               String   @id @default(uuid())
  tenantId         String
  academicYearId   String
  sectionId        String
  takenById        String?
  attendanceTypeId String

  date            DateTime @db.Date

  periodId        String?
  sectionSubjectId String?
  examScheduleId  String?

  shift           String?

  notes           String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  academicYear    AcademicYear       @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  section         Section            @relation(fields: [sectionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  attendanceType  AttendanceType     @relation(fields: [attendanceTypeId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  takenBy         User?              @relation(fields: [takenById, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  period          TimetablePeriod?   @relation(fields: [periodId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  sectionSubject  SectionSubject?    @relation(fields: [sectionSubjectId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  examSchedule    ExamSchedule?      @relation(fields: [examScheduleId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  marks AttendanceMark[]

  @@unique([tenantId, sectionId, date, attendanceTypeId, periodId])
  @@unique([id, tenantId])
  @@index([tenantId, sectionId, date])
  @@index([tenantId, academicYearId])
  @@index([tenantId, attendanceTypeId])
  @@index([tenantId, takenById])
  @@map("attendance_sessions")
}

model AttendanceMark {
  id           String           @id @default(uuid())
  tenantId     String
  sessionId    String
  enrollmentId String
  status       AttendanceStatus @default(present)
  remarks      String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  session    AttendanceSession @relation(fields: [sessionId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  enrollment StudentEnrollment @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, sessionId, enrollmentId])
  @@index([tenantId, enrollmentId])
  @@index([tenantId, sessionId])
  @@map("attendance_marks")
}

// ---------------- Staff Attendance (Multi-session per day) ----------------
/// Daily parent record — one per staff per day.
/// Consolidated status and total duration across all sessions.
model StaffAttendance {
  id              String    @id @default(uuid())
  tenantId        String
  teacherId       String

  date            DateTime  @db.Date // attendance date

  // Convenience: most recent check-in and check-out
  checkInTime     DateTime?
  checkOutTime    DateTime?

  // Derived status for the day
  status          String    @default("pending") // "pending" | "checked_in" | "checked_out" | "absent" | "on_leave"

  // Consolidated: total minutes present across all completed sessions
  totalMinutes    Int       @default(0)

  // Number of sessions (check-in/check-out cycles)
  sessionCount    Int       @default(0)

  remarks         String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teacher Teacher @relation(fields: [teacherId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  sessions StaffAttendanceSession[]

  @@unique([tenantId, teacherId, date], name: "uniqueStaffAttendancePerDay")
  @@unique([id, tenantId], name: "staff_attendance_tenant_identity")
  @@index([tenantId, date])
  @@index([tenantId, teacherId])
  @@index([tenantId, date, status])
  @@map("staff_attendance")
}

/// Individual check-in/check-out session within a day.
/// A staff member can have multiple sessions (check-in → break-out → break-in → check-out).
model StaffAttendanceSession {
  id            String    @id @default(uuid())
  tenantId      String
  attendanceId  String    // FK to parent StaffAttendance

  // Check-in
  checkInTime   DateTime  // actual timestamp of check-in
  checkInLat    Float?    // GPS latitude at check-in
  checkInLng    Float?    // GPS longitude at check-in
  checkInAccuracy Float?  // GPS accuracy in meters (optional)
  checkInMethod String?   // "gps" | "manual" | "qr"

  // Check-out
  checkOutTime  DateTime? // actual timestamp of check-out (null if still in)
  checkOutLat   Float?    // GPS latitude at check-out
  checkOutLng   Float?    // GPS longitude at check-out
  checkOutAccuracy Float?  // GPS accuracy in meters (optional)
  checkOutMethod String?  // "gps" | "manual"

  // Duration in minutes (calculated when check-out happens)
  durationMinutes Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attendance StaffAttendance  @relation(fields: [attendanceId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "staff_attendance_session_tenant_identity")
  @@index([tenantId, attendanceId])
  @@map("staff_attendance_sessions")
}

// ---------------- Parents (domain + optional login) ----------------
model Parent {
  id       String  @id @default(uuid())
  tenantId String
  userId   String? @unique

  fullName      String
  phone         String?
  email         String?
  relation      String // Father / Mother / Guardian
  aadhaarNumber String?
  occupation    String?

  registrationToken    String?   @unique
  registrationTokenExp DateTime?
  isRegistered         Boolean   @default(false)

  status    EntityStatus @default(active)
  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user   User?  @relation(fields: [userId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  students StudentParent[]

  visitors Visitor[]

  @@unique([userId, tenantId], name: "parent_user_tenant_unique")
  @@unique([id, tenantId], name: "parent_tenant_identity")
  @@unique([tenantId, phone], name: "parent_phone_per_tenant")
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@map("parents")
}

model StudentParent {
  id        String  @id @default(uuid())
  tenantId  String
  studentId String
  parentId  String
  isPrimary Boolean @default(false)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  student Student @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  parent  Parent  @relation(fields: [parentId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, studentId, parentId], name: "uniqueStudentParent")
  @@index([tenantId, studentId])
  @@index([tenantId, parentId])
  @@map("student_parents")
}

// Exams, Grading, Holidays, Students, Inventory, Uploads, Fees, Store, Payroll, Accounts, Visitor — omitted for brevity
model Exam {
  id             String @id @default(uuid())
  tenantId       String
  academicYearId String
  name        String
  description String?
  examType    ExamType
  status      ExamStatus @default(draft)
  startDate   DateTime
  endDate     DateTime
  source String @default("admin")
  gradingScaleId String?
  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
