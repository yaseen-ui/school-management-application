// ---------------- Leave Management Module ----------------

/// Leave categories — tenant-configurable for both student and employee leave.
model LeaveCategory {
  id            String             @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  applicantType LeaveApplicantType
  isActive      Boolean            @default(true)
  sortOrder     Int                @default(0)

  // Employee policy fields (nullable for student categories)
  daysAllocated       Float?
  isPaid              Boolean             @default(true)
  requiresApproval    Boolean             @default(true)
  allowHalfDay        Boolean             @default(false)
  requireDocuments    Boolean             @default(false)
  requireDocsAfterDays Float?
  allowCarryForward   Boolean             @default(false)
  maxCarryForward     Float?
  allowNegativeBalance Boolean            @default(false)
  allocationMethod    LeaveAllocationMethod @default(annual)

  // Student-specific approval mode
  studentApprovalMode  String? // "none" | "section_incharge" | "admin" | "section_incharge_then_admin"

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequests LeaveRequest[]
  balances     EmployeeLeaveBalance[]

  @@unique([tenantId, name, applicantType], name: "uniqueLeaveCategoryPerTenant")
  @@unique([id, tenantId], name: "leave_category_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, applicantType])
  @@map("leave_categories")
}

/// Per-employee, per-category, per-academic-year balance.
model EmployeeLeaveBalance {
  id              String   @id @default(uuid())
  tenantId        String
  employeeId      String
  leaveCategoryId String
  academicYearId  String

  allocated         Float @default(0)
  carriedForward    Float @default(0)
  manualAdjustment  Float @default(0)
  used              Float @default(0)
  pending           Float @default(0)
  // available = allocated + carriedForward + manualAdjustment - used - pending

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee      Teacher       @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  leaveCategory LeaveCategory @relation(fields: [leaveCategoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  academicYear  AcademicYear  @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  transactions LeaveBalanceTransaction[]

  @@unique([tenantId, employeeId, leaveCategoryId, academicYearId], name: "uniqueLeaveBalance")
  @@unique([id, tenantId], name: "employee_leave_balance_tenant_identity")
  @@index([tenantId, employeeId])
  @@index([tenantId, leaveCategoryId])
  @@index([tenantId, academicYearId])
  @@map("employee_leave_balances")
}

/// Audit trail for every balance change.
model LeaveBalanceTransaction {
  id         String   @id @default(uuid())
  tenantId   String
  balanceId  String

  changeType String // allocation | carry_forward | manual_adjustment | request_approved | request_cancelled | request_withdrawn | request_rejected_restore
  amount     Float
  reason     String?
  referenceType String? // "leave_request" | "manual_adjustment" | "carry_forward"
  referenceId   String?

  previousBalance Float
  newBalance      Float
  actorId         String?

  createdAt DateTime @default(now())

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  balance EmployeeLeaveBalance @relation(fields: [balanceId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "leave_balance_transaction_tenant_identity")
  @@index([tenantId, balanceId])
  @@index([tenantId, createdAt])
  @@map("leave_balance_transactions")
}

/// Core leave request — for both students and employees.
model LeaveRequest {
  id            String              @id @default(uuid())
  tenantId      String
  applicantType LeaveApplicantType

  // Student-specific
  studentId    String?
  enrollmentId String?

  // Employee-specific
  employeeId String?

  // Common fields
  leaveCategoryId String
  startDate       DateTime  @db.Date
  endDate         DateTime  @db.Date
  startFraction   LeaveDayFraction @default(full_day)
  endFraction     LeaveDayFraction @default(full_day)
  reason          String
  status          LeaveRequestStatus @default(draft)
  calculatedDays  Float?

  supportingDocumentUrl String?

  // Submission / withdrawal
  submittedById    String?
  submittedAt      DateTime?
  withdrawnAt      DateTime?
  withdrawnReason  String?

  deletedAt DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveCategory LeaveCategory  @relation(fields: [leaveCategoryId, tenantId], references: [id, tenantId], onDelete: Restrict, onUpdate: Cascade)
  student       Student?       @relation(fields: [studentId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  enrollment    StudentEnrollment? @relation(fields: [enrollmentId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)
  employee      Teacher?       @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  approvals     LeaveApproval[]
  cancellations LeaveCancellation[]
  auditLogs     LeaveAuditLog[]
  notifications LeaveNotification[]
  lossOfPays    EmployeeLeaveLossOfPay[]

  @@unique([id, tenantId], name: "leave_request_tenant_identity")
  @@index([tenantId, studentId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, leaveCategoryId])
  @@index([tenantId, startDate])
  @@index([tenantId, endDate])
  @@map("leave_requests")
}

/// Approval chain entries for multi-level approval.
model LeaveApproval {
  id             String   @id @default(uuid())
  tenantId       String
  leaveRequestId String
  level          Int      // 1, 2, 3...
  approverRole   String   // reporting_manager | section_incharge | department_head | principal | hr | admin
  approverId     String?
  status         String   @default("pending") // pending | approved | rejected
  remarks        String?

  decidedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "leave_approval_tenant_identity")
  @@unique([tenantId, leaveRequestId, level], name: "uniqueApprovalLevel")
  @@index([tenantId, leaveRequestId])
  @@index([tenantId, approverId])
  @@index([tenantId, status])
  @@map("leave_approvals")
}

/// Cancellation requests for approved leave.
model LeaveCancellation {
  id             String   @id @default(uuid())
  tenantId       String
  leaveRequestId String
  requestedById  String
  reason         String
  status         String   @default("pending") // pending | approved | rejected
  approverId     String?
  approverRemarks String?

  requestedAt DateTime @default(now())
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "leave_cancellation_tenant_identity")
  @@unique([tenantId, leaveRequestId], name: "oneCancellationPerRequest")
  @@index([tenantId, leaveRequestId])
  @@index([tenantId, status])
  @@map("leave_cancellations")
}

/// Immutable audit trail for leave requests.
model LeaveAuditLog {
  id             String   @id @default(uuid())
  tenantId       String
  leaveRequestId String
  action         String   // created | submitted | approved | rejected | withdrawn | cancelled | edited
  actorId        String?
  actorName      String?
  actorRole      String?
  changes        Json?
  remarks        String?

  createdAt DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "leave_audit_log_tenant_identity")
  @@index([tenantId, leaveRequestId])
  @@index([tenantId, createdAt])
  @@map("leave_audit_logs")
}

/// Notifications for leave events.
model LeaveNotification {
  id             String   @id @default(uuid())
  tenantId       String
  leaveRequestId String
  sentToId       String?
  type           String   // submitted | approval_required | approved | rejected | withdrawn | cancelled | documents_requested | timetable_affected | low_balance
  message        String?
  isRead         Boolean  @default(false)
  readAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequest LeaveRequest @relation(fields: [leaveRequestId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "leave_notification_tenant_identity")
  @@index([tenantId, leaveRequestId])
  @@index([tenantId, sentToId])
  @@index([tenantId, isRead])
  @@map("leave_notifications")
}

/// Tracks loss-of-pay days for payroll consumption.
model EmployeeLeaveLossOfPay {
  id             String   @id @default(uuid())
  tenantId       String
  leaveRequestId String
  employeeId     String
  payrollBatchId String?
  days           Float
  status         String   @default("pending") // pending | consumed

  createdAt  DateTime @default(now())
  consumedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  leaveRequest LeaveRequest  @relation(fields: [leaveRequestId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  employee     Teacher       @relation(fields: [employeeId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)
  payrollBatch PayrollBatch? @relation(fields: [payrollBatchId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id, tenantId], name: "employee_leave_loss_of_pay_tenant_identity")
  @@unique([tenantId, leaveRequestId], name: "oneLOPPerRequest")
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, payrollBatchId])
  @@map("employee_leave_loss_of_pay")
}

/// Tenant-level leave configuration.
model TenantLeaveConfiguration {
  id                String      @id @default(uuid())
  tenantId          String      @unique
  workingDays       DayOfWeek[] @default([Monday, Tuesday, Wednesday, Thursday, Friday])
  allowSaturdayHalfDay Boolean  @default(false)
  allowLeaveWithoutApproval Boolean @default(false)
  lowBalanceAlertThreshold   Float?
  enableLowBalanceAlert      Boolean @default(false)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([id, tenantId], name: "tenant_leave_configuration_tenant_identity")
  @@map("tenant_leave_configurations")
}

// ---------------- ID Sequence Patterns ----------------
/// Defines the auto-increment pattern for admission numbers and employee codes.
/// Pattern uses {SEQ:N} placeholder where N is the zero-padded sequence length.
/// e.g., "13091A{SEQ:4}" with currentSeq=562 generates "13091A0563"
model IdSequencePattern {
  id             String   @id @default(uuid())
  tenantId       String
  academicYearId String?
  entityType     String   // "admission" | "employee_code"

  pattern        String   // User-defined pattern, e.g. "13091A{SEQ:4}", "EMP-{SEQ:5}"
  currentSeq     Int      @default(0)  // Last generated sequence number
  seqLength      Int      @default(4)  // Zero-padded length for the sequence part

  isActive       Boolean  @default(true)

  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId, tenantId], references: [id, tenantId], onDelete: SetNull, onUpdate: Cascade)

  logs IdSequenceLog[]

  @@unique([tenantId, entityType, academicYearId], name: "uniquePatternPerEntityPerYear")
  @@unique([id, tenantId], name: "id_sequence_pattern_tenant_identity")
  @@index([tenantId])
  @@index([tenantId, entityType])
  @@map("id_sequence_patterns")
}

// ---------------- ID Sequence Audit Log ----------------
/// Records every generated ID for traceability.
model IdSequenceLog {
  id             String   @id @default(uuid())
  tenantId       String
  patternId      String
  generatedValue String   // The actual generated ID (e.g., "13091A0563")
  entityType     String   // "admission" | "employee_code"
  entityId       String?  // Reference to the student/teacher who received it

  createdAt DateTime @default(now())

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pattern IdSequencePattern  @relation(fields: [patternId, tenantId], references: [id, tenantId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, generatedValue], name: "uniqueGeneratedValue")
  @@index([tenantId, entityType])
  @@index([tenantId, entityId])
  @@index([tenantId, createdAt])
  @@map("id_sequence_logs")
}