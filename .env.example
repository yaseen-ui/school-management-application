# Required environment variables for the school management application

# Prisma / database connection
#DATABASE_URL=postgresql://neondb_owner:npg_Z5RLY8zTfOUm@ep-lucky-fire-aihjscvs-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require
# Local dev alternative:
DATABASE_URL=postgresql://super_admin:Shabbu@05@localhost:5432/school_management?schema=public

# JWT for auth signing
JWT_SECRET=replace_with_your_jwt_secret

# Logging level
LOG_LEVEL=info

# Local server port (if used by backend API server)
PORT=5001

# Google Cloud Storage settings
GOOGLE_CLOUD_PROJECT_ID=compact-gadget-449609-h1
GCS_BUCKET_NAME=school-management-uploads
GCS_SERVICE_ACCOUNT_PATH=./config/google-service-key.json

# Twilio SMS settings
TWILIO_ACCOUNT_SID=replace_with_your_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_your_twilio_auth_token
TWILIO_PHONE_NUMBER=+18782255926

# DeepSeek AI configuration (for ZAI Query Bot)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Next.js public env vars used by the frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/api
# NEXT_PUBLIC_HOST_TYPE=tenant
NEXT_PUBLIC_HOST_TYPE=company

# Communication module — channel enablement flags
COMM_IN_APP_ENABLED=true
COMM_EMAIL_ENABLED=false
COMM_SMS_ENABLED=false
COMM_PUSH_ENABLED=false
